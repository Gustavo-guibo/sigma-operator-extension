{
  "manifest_version": 3,
  "name": "Sigma Operator",
  "version": "1.2.0",
  "description": "Oculta automaticamente cards do Sigma Cloud que estão sendo tratados pelo Sigma Operator.",
  "author": "Team Everest",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Sigma Operator",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://cloud.segware.com.br/*"
      ],
      "js": [
        "content/content.js"
      ],
      "css": [
        "content/content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "tabs",
    "alarms"
  ],
  "host_permissions": [
    "https://cloud.segware.com.br/*",
    "https://*.supabase.co/*"
  ],
  "key": ""
}
